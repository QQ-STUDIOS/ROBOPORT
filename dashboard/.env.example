# ROBOPORT Ops Console — Docker env
# Copy to dashboard/.env (gitignored) and fill in your key.
#
#   cp dashboard/.env.example dashboard/.env
#   # edit dashboard/.env, then:
#   docker compose -f dashboard/docker-compose.yml up --build

# Anthropic API key — get one at https://console.anthropic.com/settings/keys
# Leave blank to run the keyless sample-replay demo instead of a live crew.
ANTHROPIC_API_KEY=

# Optional model overrides (defaults baked into providers.py)
# ANTHROPIC_MODEL_REASONING=claude-opus-4-7
# ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6

# Live crew runs per eval (more = more API calls / cost)
ROBOPORT_RUNS=1
