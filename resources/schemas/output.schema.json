{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://roboport.dev/schemas/output.schema.json",
  "title": "RoboportOutputs",
  "description": "Typed outputs flowing between ROBOPORT agents. Each definition matches the contract in the corresponding agents/*.md file.",
  "definitions": {
    "Job": {
      "type": "object",
      "required": ["id", "title", "company", "location", "source", "source_url", "posted_at"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "company": { "type": "string" },
        "location": { "type": "string" },
        "source": { "type": "string" },
        "source_url": { "type": "string", "format": "uri" },
        "posted_at": { "type": "string", "format": "date" },
        "raw_description": { "type": "string" },
        "salary_hint": { "type": ["string", "null"] }
      }
    },
    "TechnicalAnalysis": {
      "type": "object",
      "required": ["job_id", "stack", "seniority_signal", "confidence"],
      "properties": {
        "job_id": { "type": "string" },
        "stack": {
          "type": "object",
          "required": ["must_have", "nice_to_have"],
          "properties": {
            "must_have":     { "type": "array", "items": { "type": "string" } },
            "nice_to_have":  { "type": "array", "items": { "type": "string" } },
            "buzzword_only": { "type": "array", "items": { "type": "string" } }
          }
        },
        "seniority_signal": { "type": "string", "enum": ["Junior", "Mid", "Senior", "Staff", "Principal", "Director+"] },
        "team_shape": { "type": "string" },
        "red_flags": { "type": "array", "items": { "type": "string" } },
        "skills_overlap_with_profile": { "type": "number", "minimum": 0, "maximum": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "ComplianceAnalysis": {
      "type": "object",
      "required": ["job_id", "regulated_data", "frameworks_implied", "findings", "confidence"],
      "properties": {
        "job_id": { "type": "string" },
        "regulated_data":     { "type": "array", "items": { "type": "string" } },
        "frameworks_implied": { "type": "array", "items": { "type": "string" } },
        "geographic_constraints": { "type": "array", "items": { "type": "string" } },
        "clearance_required": { "type": "boolean" },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "severity", "evidence", "citation_url"],
            "properties": {
              "kind":         { "type": "string" },
              "severity":     { "type": "string", "enum": ["informational", "low", "medium", "high", "critical"] },
              "evidence":     { "type": "string" },
              "citation_url": { "type": "string", "format": "uri" }
            }
          }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "CandidateMatch": {
      "type": "object",
      "required": ["job_id", "fit_score", "verdict", "priority"],
      "properties": {
        "job_id":     { "type": "string" },
        "fit_score":  { "type": "number", "minimum": 0, "maximum": 1 },
        "verdict":    { "type": "string", "enum": ["apply", "tailor_first", "skip", "research_more"] },
        "reasoning_for":     { "type": "array", "items": { "type": "string" } },
        "reasoning_against": { "type": "array", "items": { "type": "string" } },
        "recommended_actions": { "type": "array", "items": { "type": "string" } },
        "priority": { "type": "integer", "minimum": 1, "maximum": 5 }
      }
    },
    "SalaryBand": {
      "type": "object",
      "required": ["job_id", "band", "sources", "confidence"],
      "properties": {
        "job_id": { "type": "string" },
        "band": {
          "type": "object",
          "required": ["low", "mid", "high", "currency"],
          "properties": {
            "low":  { "type": "number" },
            "mid":  { "type": "number" },
            "high": { "type": "number" },
            "currency": { "type": "string", "minLength": 3, "maxLength": 3 }
          }
        },
        "components": {
          "type": "object",
          "properties": {
            "base":              { "type": "number" },
            "bonus":             { "type": "number" },
            "equity_per_year":   { "type": "number" }
          }
        },
        "sources": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["name", "weight"],
            "properties": {
              "name":   { "type": "string" },
              "url":    { "type": "string" },
              "weight": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        },
        "confidence": { "type": "string", "enum": ["low", "medium", "high"] }
      }
    },
    "FinalReport": {
      "type": "object",
      "required": ["generated_at", "summary", "ranked_matches"],
      "properties": {
        "generated_at": { "type": "string", "format": "date-time" },
        "query": { "type": "object" },
        "summary": {
          "type": "object",
          "required": ["total_jobs", "verdicts"],
          "properties": {
            "total_jobs": { "type": "integer", "minimum": 0 },
            "verdicts":   { "type": "object" }
          }
        },
        "ranked_matches": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["rank", "job", "match"],
            "properties": {
              "rank":       { "type": "integer", "minimum": 1 },
              "job":        { "$ref": "#/definitions/Job" },
              "technical":  { "$ref": "#/definitions/TechnicalAnalysis" },
              "compliance": { "$ref": "#/definitions/ComplianceAnalysis" },
              "match":      { "$ref": "#/definitions/CandidateMatch" },
              "salary":     { "$ref": "#/definitions/SalaryBand" }
            }
          }
        },
        "warnings": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
