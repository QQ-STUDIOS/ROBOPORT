{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://roboport.dev/schemas/eval.schema.json",
  "title": "EvalSet",
  "type": "object",
  "required": ["target", "evals"],
  "properties": {
    "target": {
      "type": "string",
      "description": "The agent or crew this eval set targets, e.g. 'job_scout' or 'jd_crew'."
    },
    "version": { "type": "string" },
    "evals": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/Eval" }
    }
  },
  "definitions": {
    "Eval": {
      "type": "object",
      "required": ["id", "prompt", "expectations"],
      "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "prompt": { "type": "string", "minLength": 1 },
        "expected_output": {
          "type": "string",
          "description": "Human-readable description of success."
        },
        "files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional input file paths (relative to repo root)."
        },
        "expectations": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Verifiable assertions the Grader can check."
        },
        "blockers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Subset of expectations that, if any fail, fail the whole eval."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
