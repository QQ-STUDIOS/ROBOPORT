# ROBOPORT environment variables
#
# Copy to .env and fill in values you need. .env is gitignored.
# Defaults are baked into scripts/roboport_runtime/providers.py — only set
# what you want to override.

# ─── Provider selection ──────────────────────────────────────────────────
# Which model backend to use. Affects benchmark.py / runtime providers.
#   ollama    — local, default. Requires Ollama running on OLLAMA_HOST.
#   anthropic — Claude API. Requires ANTHROPIC_API_KEY.
ROBOPORT_PROVIDER=ollama

# ─── Ollama (local) ──────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_REASONING=qwen3.5:latest
OLLAMA_MODEL_DEFAULT=gemma4:latest

# ─── Anthropic (cloud) ───────────────────────────────────────────────────
# Get a key at https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_REASONING=claude-opus-4-7
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6

# ─── Tool API keys (job_scout / aggregator) ──────────────────────────────
# Required only for the corresponding tool integrations in
# config/agent_config.yaml. Leave unset to disable that tool.
# LINKEDIN_API_KEY=
# INDEED_API_KEY=
# SERPAPI_KEY=
